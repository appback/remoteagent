{
  "name": "remoteagent",
  "version": "0.7.0",
  "private": true,
  "description": "Personal installable session server for continuing local AI work across PC and Telegram",
  "license": "MIT",
  "type": "module",
  "bin": {
    "remoteagent-report": "dist/report-telegram.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build",
    "version:patch": "npm version --no-git-tag-version patch",
    "version:minor": "npm version --no-git-tag-version minor",
    "version:major": "npm version --no-git-tag-version major"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "grammy": "^1.38.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "scripts",
    "docs",
    "README.md",
    "LICENSE",
    ".env.example",
    "package.json",
    "tsconfig.json"
  ]
}
